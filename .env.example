# ─── Seguridad y autenticación ───
# Clave secreta para firmar sesiones Flask. Genera una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=genera_una_clave_secreta_aleatoria

# Credenciales de acceso (login único, se sustituirá por multi-usuario en Fase 5)
ADMIN_USER=admin
ADMIN_PASSWORD=cambia_esta_contraseña

# ─── API Keys ───
# OpenAI: para OCR con visión (GPT-4o) al procesar facturas
# Obtener en https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# OpenRouteService: geocoding y rutas para módulo de Transporte (opcional)
# Obtener en https://openrouteservice.org/dev/#/signup
OPENROUTESERVICE_API_KEY=

# ─── OCR (opcional) ───
# Ruta al ejecutable de Tesseract si se usa OCR local como fallback
# En Windows suele ser: C:\Program Files\Tesseract-OCR\tesseract.exe
# Dejar vacío si no se usa Tesseract
TESSERACT_CMD=
