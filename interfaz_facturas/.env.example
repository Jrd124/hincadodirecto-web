# ── Hincado ERP – Variables de entorno ──
# Copia este archivo a .env y ajusta los valores.
#   cp .env.example .env

# Autenticación
ADMIN_USER=admin
ADMIN_PASSWORD=admin
SECRET_KEY=cambia-esta-clave-en-produccion

# OpenAI (opcional – clasificador de documentos CAE)
OPENAI_API_KEY=

# OpenRouteService (opcional – cálculo de rutas en Transporte)
OPENROUTESERVICE_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPERADMIN_IDS=     # comma-separated Telegram user IDs

# Microsoft Graph / OneDrive (sincronización CAE)
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
SHAREPOINT_SITE=           # ej: hincadodirecto.sharepoint.com:/sites/MiSite
SHAREPOINT_DOC_LIBRARY=Shared Documents
SHAREPOINT_ROOT_FOLDER=ERP Hincado Directo
