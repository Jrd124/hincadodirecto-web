# ── Hincado ERP – Variables de entorno ──
# Copia este archivo a .env y ajusta los valores.
#   cp .env.example .env

# Autenticación
ADMIN_USER=admin
ADMIN_PASSWORD=admin
SECRET_KEY=cambia-esta-clave-en-produccion

# OpenAI (opcional – clasificador de documentos CAE)
OPENAI_API_KEY=

# OpenRouteService (opcional – cálculo de rutas en Transporte)
OPENROUTESERVICE_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPERADMIN_IDS=     # comma-separated Telegram user IDs

# Microsoft Graph / OneDrive (sincronización CAE)
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
SHAREPOINT_SITE=           # ej: hincadodirecto.sharepoint.com:/sites/MiSite
SHAREPOINT_DOC_LIBRARY=Shared Documents
SHAREPOINT_ROOT_FOLDER=ERP Hincado Directo

# ── Gmail CRM (Fase 3) ──────────────────────────────────────────────────────
# Obtén CLIENT_ID y CLIENT_SECRET en Google Cloud Console → APIs & Services → Credentials
# Ejecuta una vez: python scripts/gmail_oauth_setup.py  → guarda el REFRESH_TOKEN automáticamente
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=           # se rellena automáticamente con gmail_oauth_setup.py
GMAIL_ACCOUNT=direccion@hincadodirecto.com
CRM_GMAIL_BATCH_SIZE=20        # empresas por run global
CRM_GMAIL_MAX_THREADS=10       # hilos por empresa por sync
